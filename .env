# ==============================================
# CONFIGURACIÓN FELICITA - DESARROLLO LOCAL
# ==============================================

# Configuración General
DJANGO_SECRET_KEY=tu-clave-secreta-super-segura-aqui-2024-felicita
DJANGO_DEBUG=True
DJANGO_ENVIRONMENT=local

# Base de Datos PostgreSQL Local
DATABASE_NAME=felicita_db
DATABASE_USER=felicita_user
DATABASE_PASSWORD=felicita_password_2024
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis (Cache)
REDIS_URL=redis://localhost:6379/0

# CORS - Frontend Local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# JWT Configuración
JWT_SECRET_KEY=jwt-secret-key-felicita-2024-super-seguro
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Nubefact API (Modo DEMO/TEST)
NUBEFACT_TOKEN=tu-token-demo-aqui
NUBEFACT_RUC=20123456789
NUBEFACT_USUARIO_SOL=MODDATOS
NUBEFACT_CLAVE_SOL=MODDATOS
NUBEFACT_MODE=demo
NUBEFACT_BASE_URL=https://demo-ose.nubefact.com/ol-ti-itcpe/billService

# APIs Externas Perú
RENIEC_TOKEN=tu-token-reniec-aqui
SUNAT_CONSULTA_RUC_URL=https://api.sunat.gob.pe/v1/contribuyente/contribuyentes/

# Configuración Email (para notificaciones)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Configuración de Archivos
MEDIA_ROOT=media/
STATIC_ROOT=static/
MAX_UPLOAD_SIZE=10485760  # 10MB

# Logging
LOG_LEVEL=DEBUG
LOG_TO_FILE=False

# Configuración de Empresa por Defecto
EMPRESA_RUC=20123456789
EMPRESA_RAZON_SOCIAL=EMPRESA DEMO FELICITA S.A.C.
EMPRESA_DIRECCION=Av. Lima 123, Lima, Lima, Perú
EMPRESA_TELEFONO=+51 1 234-5678
EMPRESA_EMAIL=demo@felicita.pe

# Configuración SUNAT
IGV_RATE=0.18
MONEDA_NACIONAL=PEN

# Timezone
TIME_ZONE=America/Lima

# Configuración de Seguridad
SECURE_SSL_REDIRECT=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# Rate Limiting
RATELIMIT_ENABLE=True
RATELIMIT_PER_MINUTE=60

# Configuración de Backup
BACKUP_ENABLED=False
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM